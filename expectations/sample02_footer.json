    { "expectation_type": "expect_column_values_to_be_in_set", "kwargs": { "column": "REC_TYPE", "value_set": ["EOF"] } },

    { "expectation_type": "expect_column_values_to_not_be_null", "kwargs": { "column": "RECORD_COUNT" } },
    { "expectation_type": "expect_column_values_to_be_numeric", "kwargs": { "column": "RECORD_COUNT", "permitir_negativos": false, "permitir_decimales": false } },

    { "expectation_type": "expect_column_values_to_not_be_null", "kwargs": { "column": "SUM_BALANCE" } },
