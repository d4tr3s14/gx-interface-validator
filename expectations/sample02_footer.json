    { "expectation_type": "expect_table_to_have_no_duplicate_rows",
      "kwargs": { "section": "footer", "max_error_details": 20 } },

    { "expectation_type": "expect_column_to_exist", "kwargs": { "column": "REC_TYPE" } },
